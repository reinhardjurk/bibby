project_id      = "11111111-1111-1111-1111-111111111111"
region          = "fr-par"
zone            = "fr-par-1"
app_name        = "bibby"
bucket_suffix   = "prod-7f3a"   # beliebig, aber global eindeutig

public_base_url = "https://anmeldung.bibby.example"
tem_domain      = "mail.bibby.example"
tem_from_name   = "Bibby"
cors_origins    = ["https://anmeldung.bibby.example"]

# E-Mail Test-Modus: true = ALLE Mails gehen an mail_test_recipient.
# Vor dem Echtbetrieb auf false setzen.
mail_test_mode      = true
mail_test_recipient = "test@bibby.example"

sepa_creditor_name = "Bibby Lauf e.V."
sepa_creditor_id   = "DE00ZZZ00000000000"

# Secrets besser via TF_VAR_* aus der Umgebung setzen statt hier eintragen:
#   export TF_VAR_app_secret_key=...
#   export TF_VAR_field_encryption_key=$(python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
#   export TF_VAR_tem_secret_key=...   # nur der Secret Key des Scaleway-API-Keys
app_secret_key       = "change-me"
field_encryption_key = "change-me-fernet-key"
tem_secret_key       = ""
